# ── Using Groq API as its free currently ──────────────────────────────────────────────────────────────────
# Update base url with https://inference.do-ai.run/v1 and API key with your_do_gradient_key_here instead of groqapi key 

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GRADIENT_MODEL=llama-3.3-70b-versatile

# ── Ed25519 JWT Keys (asymmetric — replaces JWT_SECRET) ───────────────────────
# Generate with:  npm run generate-keys
#
# JWT_PRIVATE_KEY  → signs tokens   (keep secret, never commit)
# JWT_PUBLIC_KEY   → verifies tokens (safe to share)
JWT_PRIVATE_KEY={"kty":"OKP","crv":"Ed25519","x":"...","d":"..."}
JWT_PUBLIC_KEY={"kty":"OKP","crv":"Ed25519","x":"..."}

JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ANALYZE_RATE_LIMIT_MAX=10
